__pycache__/
*.pyc
.DS_Store
.pytest_cache/
*.tmp*

# Cache: ignore parquet/pkl/json by default, then un-ignore the small committed
# snapshot files the deploy image needs. Raw boxscore JSON (2.8GB) stays OUT of
# git and rebuilds from the API. The per-season gamelog parquets ARE committed
# (~9MB total): the daily GitHub Action needs them to append each day's games
# without a full refetch, and a fresh clone gets working features offline.
cache/*.parquet
cache/*.pkl
cache/*.json
cache/*.log
cache/raw_boxscores/
!cache/gamelogs_*.parquet
!cache/park_factors_*.parquet
!cache/statcast_*.parquet
!cache/sprint_speed_*.parquet
!cache/arsenal_*.parquet
!cache/disc_*.parquet
!cache/game_weather_v1.parquet
!cache/venues_v1.parquet
!cache/tto_pit_*.parquet
!cache/fbvelo_*.parquet
!cache/catcher_framing_*.parquet
!cache/catcher_throwing_*.parquet
!cache/player_universe_*.parquet
!cache/predictions_*.parquet
!cache/slate_*.json
!cache/accuracy_history_*.parquet
